<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>สมัครสมาชิก - ComRepair</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <style>
        body {
            background-color: #f4f7fa;
        }
        .signup-card {
            max-width: 450px;
            width: 100%;
            border-radius: 15px;
        }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center vh-100">

    <div class="card shadow border-0 signup-card p-4">
        <div class="card-body">
            <div class="text-center mb-4">
                <i class="bi bi-tools text-primary" style="font-size: 3rem;"></i>
                <h3 class="fw-bold mt-2 text-dark">ComRepair</h3>
                <p class="text-muted">สร้างบัญชีผู้ใช้งานใหม่</p>
            </div>

            <form id="signupForm">
                <div class="mb-3">
                    <label class="form-label fw-bold text-secondary">ชื่อผู้ใช้งาน (Username) <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-person"></i></span>
                        <input type="text" class="form-control" id="username" required placeholder="ตั้งชื่อผู้ใช้งาน (เช่น admin01)">
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold text-secondary">อีเมล (Email) <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-envelope"></i></span>
                        <input type="email" class="form-control" id="email" required placeholder="กรอกอีเมลของคุณ">
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold text-secondary">รหัสผ่าน (Password) <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-lock"></i></span>
                        <input type="password" class="form-control" id="password" required placeholder="ตั้งรหัสผ่าน">
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary">ยืนยันรหัสผ่าน (Confirm Password) <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-shield-check"></i></span>
                        <input type="password" class="form-control" id="confirm_password" required placeholder="กรอกรหัสผ่านอีกครั้ง">
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 fw-bold py-2 rounded-pill shadow-sm">
                    <i class="bi bi-person-plus-fill me-2"></i> สมัครสมาชิก
                </button>

                <div class="text-center mt-4">
                    <small class="text-muted">มีบัญชีอยู่แล้ว? <a href="/login" class="text-decoration-none fw-bold">เข้าสู่ระบบที่นี่</a></small>
                </div>
            </form>
        </div>
    </div>

    <script>
        document.getElementById('signupForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const username = document.getElementById('username').value;
            const email = document.getElementById('email').value; // 🌟 รับค่า Email จากฟอร์ม
            const password = document.getElementById('password').value;
            const confirm_password = document.getElementById('confirm_password').value;

            // ดักจับรหัสผ่านไม่ตรงกัน
            if (password !== confirm_password) {
                alert('❌ รหัสผ่านและการยืนยันรหัสผ่านไม่ตรงกัน!');
                return;
            }

            try {
                // ส่งข้อมูลไปบันทึกที่หลังบ้าน (เพิ่ม email เข้าไปด้วย)
                const response = await axios.post('http://localhost:5000/api/signup', {
                    username: username,
                    email: email, // 🌟 ส่งให้หลังบ้าน
                    password: password
                });
                
                if (response.data.success) {
                    alert('✅ ' + response.data.message);
                    window.location.href = '/login'; 
                }
            } catch (error) {
                console.error("สมัครสมาชิกพลาด:", error);
                if (error.response && error.response.data && error.response.data.message) {
                    alert('❌ ' + error.response.data.message);
                } else {
                    alert('❌ เกิดข้อผิดพลาด ไม่สามารถสมัครสมาชิกได้');
                }
            }
        });
    </script>
</body>
</html>