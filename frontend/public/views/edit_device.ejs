<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <h2 class="fw-bold text-dark">
            <i class="bi bi-pencil-square text-warning me-2"></i>แก้ไขข้อมูลอุปกรณ์ <span id="displayDeviceId" class="text-primary"></span>
        </h2>
        <a href="/devices" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-arrow-left"></i> กลับหน้ารายการ
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-3" style="max-width: 800px; margin: 0 auto;">
        <div class="card-body p-5">
            <form id="editDeviceForm">
                
                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary"><i class="bi bi-person-fill me-2"></i>ลูกค้าระบบ <span class="text-danger">*</span></label>
                    <select class="form-select form-select-lg" id="customer_id" required>
                        <option value="">-- กำลังโหลดข้อมูลลูกค้า --</option>
                    </select>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-12 mb-2">
                        <label class="form-label fw-bold text-secondary">ประเภทอุปกรณ์ (Device Type) <span class="text-danger">*</span></label>
                        <select class="form-select" id="device_type" required>
                            <option value="" disabled>-- คลิกเพื่อเลือกประเภท --</option>
                            <option value="PC Desktop">🖥️ PC Desktop (คอมพิวเตอร์ตั้งโต๊ะ)</option>
                            <option value="Notebook">💻 Notebook / Laptop (โน้ตบุ๊ก)</option>
                            <option value="MacBook">🍎 MacBook</option>
                            <option value="Printer">🖨️ Printer (เครื่องพิมพ์)</option>
                            <option value="Phone">📱 Phone / Tablet (มือถือ/แท็บเล็ต)</option>
                            <option value="อื่นๆ">อื่นๆ</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-secondary">ยี่ห้อ (Brand) <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="brand" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-secondary">รุ่น (Model) <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="model" required>
                    </div>
                </div>

                <hr class="mb-4">

                <div class="text-end">
                    <button type="submit" class="btn btn-warning fw-bold px-5 shadow-sm">
                        <i class="bi bi-save me-2"></i>บันทึกการแก้ไข
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('partials/footer') %>

<script>
    const urlParts = window.location.pathname.split('/');
    const currentDeviceId = urlParts[urlParts.length - 1];

    async function loadDeviceData() {
        try {
            // โหลดข้อมูลลูกค้า และ ข้อมูลอุปกรณ์เดิมมาพร้อมกัน
            const [customersRes, deviceRes] = await Promise.all([
                axios.get('http://localhost:5000/api/customers'),
                axios.get(`http://localhost:5000/api/devices/${currentDeviceId}`)
            ]);

            // นำลูกค้าใส่ Dropdown
            let custOptions = '<option value="">-- เลือกลูกค้า --</option>';
            customersRes.data.data.forEach(c => {
                custOptions += `<option value="${c.customer_id}">${c.first_name} ${c.last_name || ''} (${c.phone || 'ไม่มีเบอร์'})</option>`;
            });
            document.getElementById('customer_id').innerHTML = custOptions;

            // นำข้อมูลอุปกรณ์เดิมมากรอกลงฟอร์ม
            const d = deviceRes.data.data;
            document.getElementById('displayDeviceId').innerText = `(DEV-${String(d.device_id).padStart(3, '0')})`;
            
            document.getElementById('customer_id').value = d.customer_id;
            // 🌟 ตั้งค่าให้ Dropdown เลือกประเภทเดิมที่เคยบันทึกไว้
            document.getElementById('device_type').value = d.device_type || ''; 
            document.getElementById('brand').value = d.brand;
            document.getElementById('model').value = d.model;

        } catch (error) {
            console.error("โหลดข้อมูลพลาด:", error);
            alert("ไม่สามารถโหลดข้อมูลอุปกรณ์ได้");
        }
    }

    // เมื่อกดปุ่มบันทึก
    document.getElementById('editDeviceForm').addEventListener('submit', async function(e) {
        e.preventDefault();

        // ดึงค่าใหม่จากฟอร์ม
        const updateData = {
            customer_id: document.getElementById('customer_id').value,
            device_type: document.getElementById('device_type').value, // 🌟 ส่ง device_type ไปหลังบ้าน
            brand: document.getElementById('brand').value,
            model: document.getElementById('model').value
        };

        try {
            const response = await axios.put(`http://localhost:5000/api/devices/${currentDeviceId}`, updateData);
            
            if (response.data.success) {
                alert('✅ ' + response.data.message);
                window.location.href = '/devices';
            }
        } catch (error) {
            console.error("อัปเดตพลาด:", error);
            alert('❌ อัปเดตข้อมูลไม่สำเร็จ');
        }
    });

    loadDeviceData();
</script>

</body>
</html>