<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <h2 class="fw-bold" style="color: var(--sidebar-bg);">
            <i class="bi bi-receipt text-warning me-2"></i>แก้ไขข้อมูลบิลชำระเงิน <span id="headerPayId" class="text-primary"></span>
        </h2>
        <a href="/payments" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-arrow-left"></i> ยกเลิก / กลับ
        </a>
    </div>

    <div id="loadingBox" class="text-center py-5">
        <div class="spinner-border text-warning" role="status" style="width: 3rem; height: 3rem;"></div>
        <h5 class="mt-3 text-muted">กำลังดึงข้อมูลบิล...</h5>
    </div>

    <div class="card shadow-sm border-0 rounded-3 mx-auto" id="editFormBox" style="max-width: 800px; display: none;">
        <div class="card-body p-4 p-md-5">
            <form id="editPaymentForm">
                
                <div class="mb-4 bg-light p-3 rounded border">
                    <label class="form-label fw-bold text-success"><i class="bi bi-tools me-2"></i>อ้างอิงจากงานซ่อม (Repair ID) <span class="text-danger">*</span></label>
                    <select class="form-select form-select-lg" id="repairId" required>
                        <option value="" disabled>⏳ กำลังโหลดรายการงานซ่อม...</option>
                        </select>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <label class="form-label fw-bold text-secondary">ยอดชำระเงิน (บาท) <span class="text-danger">*</span></label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-light border-end-0">฿</span>
                            <input type="number" step="0.01" class="form-control bg-light border-start-0" id="amount" required>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-secondary">วันที่ชำระเงิน <span class="text-danger">*</span></label>
                        <input type="date" class="form-control form-control-lg bg-light" id="paymentDate" required>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <label class="form-label fw-bold text-secondary">ช่องทางการชำระเงิน <span class="text-danger">*</span></label>
                        <select class="form-select form-select-lg bg-light" id="paymentMethod" required>
                            <option value="เงินสด">💵 เงินสด (Cash)</option>
                            <option value="โอนเงิน">📱 โอนเงิน (Bank Transfer)</option>
                            <option value="บัตรเครดิต">💳 บัตรเครดิต (Credit Card)</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-secondary">สถานะบิล <span class="text-danger">*</span></label>
                        <select class="form-select form-select-lg bg-light" id="status" required>
                            <option value="Paid">✅ ชำระแล้ว</option>
                            <option value="Unpaid">❌ ค้างชำระ</option>
                        </select>
                    </div>
                </div>

                <hr class="mb-4">

                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    <button type="submit" class="btn btn-warning fw-bold text-dark btn-lg px-5 shadow-sm">
                        <i class="bi bi-save me-2"></i> บันทึกการแก้ไข
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // ดึงตัวแปร ID บิลที่ส่งมาจาก Backend
    const currentPaymentId = '<%= paymentId %>';

    // ==========================================
    // 1. ฟังก์ชันดึงข้อมูลเก่าและตัวเลือกงานซ่อม
    // ==========================================
    async function loadPaymentData() {
        try {
            // ดึงข้อมูล 2 เส้นทาง (ข้อมูลบิล + รายการงานซ่อม)
            const [paymentRes, repairsRes] = await Promise.all([
                axios.get(`http://localhost:5000/api/payments/${currentPaymentId}`),
                axios.get('http://localhost:5000/api/repairs') // ยืม API จากงานซ่อม
            ]);

            const payment = paymentRes.data.data;
            const repairs = repairsRes.data.data;

            // --- 1. จัดการ Dropdown งานซ่อม ---
            let repOptions = '<option value="" disabled>-- คลิกลูกศรเพื่อเปลี่ยนงานซ่อม --</option>';
            repairs.forEach(r => {
                const repId = String(r.repair_id).padStart(3, '0');
                // ล็อกตัวเลือกให้ตรงกับบิลเดิม
                const isSelected = (r.repair_id === payment.repair_id) ? 'selected' : '';
                repOptions += `<option value="${r.repair_id}" ${isSelected}>REP-${repId} | ลูกค้า: ${r.customer_name || 'ไม่ระบุ'} (${r.device_name || '-'})</option>`;
            });
            document.getElementById('repairId').innerHTML = repOptions;

            // --- 2. นำข้อมูลบิลไปหยอดลงช่อง Input ---
            const payIdFormatted = String(payment.payment_id).padStart(3, '0');
            document.getElementById('headerPayId').innerText = `(PAY-${payIdFormatted})`;
            
            document.getElementById('amount').value = payment.amount || '';
            document.getElementById('paymentDate').value = payment.payment_date || '';
            
            // ตรวจสอบค่าก่อนใส่ Dropdown ถ้าค่าไม่ตรงกับ Option ที่มี อาจจะต้องใช้วิธีเซ็ตแบบยืดหยุ่น แต่แบบนี้ครอบคลุมค่าพื้นฐานครับ
            if(payment.payment_method) document.getElementById('paymentMethod').value = payment.payment_method;
            if(payment.status) document.getElementById('status').value = payment.status;

            // ปิดตัวโหลด เปิดกล่องฟอร์ม
            document.getElementById('loadingBox').style.display = 'none';
            document.getElementById('editFormBox').style.display = 'block';

        } catch (error) {
            console.error("ดึงข้อมูลพลาด:", error);
            document.getElementById('loadingBox').innerHTML = `<h5 class="text-danger mt-3">❌ ไม่พบข้อมูลบิล หรือระบบมีปัญหา</h5>`;
        }
    }

    // ==========================================
    // 2. ฟังก์ชันส่งข้อมูลใหม่ไปอัปเดต
    // ==========================================
    document.getElementById('editPaymentForm').addEventListener('submit', async function(e) {
        e.preventDefault(); 

        const data = {
            repair_id: document.getElementById('repairId').value,
            amount: document.getElementById('amount').value,
            payment_date: document.getElementById('paymentDate').value,
            payment_method: document.getElementById('paymentMethod').value,
            status: document.getElementById('status').value
        };

        try {
            // ใช้ axios.put (แก้ไขข้อมูล) ไปที่หลังบ้าน
            const response = await axios.put(`http://localhost:5000/api/payments/${currentPaymentId}`, data);

            if (response.data.success) {
                alert('✅ ' + response.data.message);
                window.location.href = '/payments'; // เด้งกลับไปหน้ารายการชำระเงิน
            }
        } catch (error) {
            console.error("ส่งข้อมูลแก้ไขพลาด:", error);
            alert('❌ เกิดข้อผิดพลาด ไม่สามารถอัปเดตข้อมูลได้');
        }
    });

    // ให้ดึงข้อมูลมาแสดงทันทีที่เปิดหน้าเว็บ
    loadPaymentData();
</script>

</body>
</html>