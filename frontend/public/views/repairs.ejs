<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-4">
    <h2 class="h4 fw-bold text-dark"><i class="bi bi-wrench-adjustable text-primary me-2"></i>รายการแจ้งซ่อมทั้งหมด</h2>
    <a href="/add_repair" class="btn btn-primary rounded-pill px-4 shadow-sm">
        <i class="bi bi-plus-lg me-1"></i> เปิดใบแจ้งซ่อมใหม่
    </a>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 12px;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="ps-4">รหัสงาน</th>
                        <th>วันที่รับเครื่อง</th>
                        <th>ลูกค้า</th>
                        <th>อุปกรณ์</th>
                        <th>สถานะ</th>
                        <th class="text-end pe-4">จัดการ</th>
                    </tr>
                </thead>
                <tbody id="repairTableBody">
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">
                            <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                            กำลังโหลดข้อมูล...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
<script>
    async function loadRepairs() {
        try {
            // 1. เรียก API ดึงข้อมูล
            const response = await axios.get('http://localhost:5000/api/repairs');
            const repairs = response.data.data;
            let html = '';

            // 2. เช็คว่ามีข้อมูลไหม
            if (repairs.length === 0) {
                html = `
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">ยังไม่มีรายการแจ้งซ่อมในขณะนี้</td>
                    </tr>
                `;
            } else {
                // 3. เอาข้อมูลมาวนลูป (ใช้ UI สวยๆ ของคุณเลย)
                repairs.forEach(r => {
                    // จัดการ Format เลขรหัส (เติม 0 ข้างหน้าให้ครบ 3 หลัก)
                    const repairIdFormatted = String(r.repair_id).padStart(3, '0');

                    // จัดการป้ายสีสถานะ
                    let statusBadge = '';
                    if(r.status === 'Pending') {
                        statusBadge = `<span class="badge bg-secondary rounded-pill px-3">รอดำเนินการ</span>`;
                    } else if(r.status === 'In Progress') {
                        statusBadge = `<span class="badge rounded-pill px-3" style="background-color: #ff6b00;">กำลังซ่อม</span>`;
                    } else if(r.status === 'Completed') {
                        statusBadge = `<span class="badge bg-success rounded-pill px-3">ซ่อมเสร็จสิ้น</span>`;
                    } else {
                        statusBadge = `<span class="badge bg-dark rounded-pill px-3">${r.status}</span>`;
                    }

                    // ปั้น HTML ทีละแถว
                    html += `
                        <tr>
                            <td class="ps-4 fw-bold text-muted">REP-${repairIdFormatted}</td>
                            <td>${r.receive_date || '-'}</td>
                            <td>
                                <div class="fw-bold">${r.first_name || ''} ${r.last_name || ''}</div>
                                <small class="text-muted">${r.phone || '-'}</small>
                            </td>
                            <td>
                                <div class="badge bg-light text-dark border-0 fw-normal p-0">${r.brand || ''} ${r.model || ''}</div>
                            </td>
                            <td>${statusBadge}</td>
                            <td class="text-end pe-3">
                                <div class="btn-group">
                                    <a href="/repair-details/${r.repair_id}" class="btn btn-sm btn-info text-white rounded-pill px-3 me-1">
                                        <i class="bi bi-search"></i> รายละเอียด
                                    </a>
                                    
                                    <a href="/edit_repair/${r.repair_id}" class="btn btn-sm btn-outline-warning rounded-circle me-1">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <form action="/delete-repair/${r.repair_id}" method="POST" class="d-inline" onsubmit="return confirm('⚠️ คำเตือน: การลบรายการแจ้งซ่อมจะทำให้ข้อมูลการชำระเงินที่เกี่ยวข้องถูกลบไปด้วย คุณต้องการดำเนินการต่อหรือไม่?');">
                                        <button type="button" class="btn btn-sm btn-light text-danger border" title="ลบ" onclick="deleteRepair(${r.repair_id})">
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    `;
                });
            }

            // 4. เอาข้อมูลยัดใส่ตาราง
            document.getElementById('repairTableBody').innerHTML = html;

        } catch (error) {
            console.error("ดึงข้อมูลพลาด:", error);
            document.getElementById('repairTableBody').innerHTML = `
                <tr><td colspan="6" class="text-center py-4 text-danger">❌ ไม่สามารถดึงข้อมูลได้ กรุณาตรวจสอบการเชื่อมต่อ</td></tr>
            `;
        }
    }

    // สั่งให้ทำงานทันทีเมื่อหน้าเว็บโหลดเสร็จ
    loadRepairs();

// ==========================================
// 🗑️ ฟังก์ชันลบงานซ่อม
// ==========================================
async function deleteRepair(id) {
    if (confirm('⚠️ อันตราย! คุณแน่ใจหรือไม่ว่าต้องการลบรายการแจ้งซ่อมนี้? (บิลการชำระเงินของงานนี้จะได้รับผลกระทบ)')) {
        try {
            const response = await axios.delete(`http://localhost:5000/api/repairs/${id}`);
            if (response.data.success) {
                alert('✅ ' + response.data.message);
                loadRepairs(); // โหลดตารางใหม่
            }
        } catch (error) {
            console.error("ลบงานซ่อมพลาด:", error);
            alert('❌ ไม่สามารถลบได้ กรุณาลองใหม่อีกครั้ง');
        }
    }
}
</script>
<%- include('partials/footer') %>