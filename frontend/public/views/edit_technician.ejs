<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <h2 class="fw-bold text-dark">
            <i class="bi bi-person-badge text-warning me-2"></i>แก้ไขข้อมูลช่างซ่อม <span id="displayTechId" class="text-primary"></span>
        </h2>
        <a href="/technicians" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-arrow-left"></i> ยกเลิก / กลับ
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-3" style="max-width: 800px; margin: 0 auto;">
        <div class="card-body p-5">
            <form id="editTechForm">
                
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-secondary">ชื่อจริง <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="first_name" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-secondary">นามสกุล <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="last_name" required>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-secondary">เบอร์โทรศัพท์ <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="phone" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-secondary">อีเมล</label>
                        <input type="email" class="form-control" id="email">
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary">
                        <i class="bi bi-calendar-check me-1 text-warning"></i> วันที่เริ่มงาน <span class="text-danger">*</span>
                    </label>
                    <input type="date" class="form-control" id="hire_date" required>
                </div>

                <hr class="mb-4">

                <div class="text-end">
                    <button type="submit" class="btn btn-warning fw-bold px-5 shadow-sm">
                        <i class="bi bi-save me-2"></i>บันทึกการแก้ไข
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('partials/footer') %>

<script>
    // ดึง ID ช่างจาก URL
    const urlParts = window.location.pathname.split('/');
    const currentTechId = urlParts[urlParts.length - 1];

    async function loadTechData() {
        try {
            // ดึงข้อมูลช่างคนเดิมมาแสดง
            const response = await axios.get(`http://localhost:5000/api/technicians/${currentTechId}`);
            const t = response.data.data;

            document.getElementById('displayTechId').innerText = `(TECH-${String(t.technician_id).padStart(3, '0')})`;
            
            // ยัดข้อมูลลงฟอร์ม
            document.getElementById('first_name').value = t.first_name;
            document.getElementById('last_name').value = t.last_name || '';
            document.getElementById('phone').value = t.phone || '';
            document.getElementById('email').value = t.email || '';
            document.getElementById('hire_date').value = t.hire_date || ''; // 🌟 ดึงวันที่เริ่มงานเก่ามาโชว์

        } catch (error) {
            console.error("โหลดข้อมูลพลาด:", error);
            alert("ไม่สามารถโหลดข้อมูลช่างซ่อมได้");
        }
    }

    // เมื่อกดปุ่มบันทึก
    document.getElementById('editTechForm').addEventListener('submit', async function(e) {
        e.preventDefault();

        // ดึงค่าใหม่จากฟอร์มเพื่อส่งไปอัปเดต
        const updateData = {
            first_name: document.getElementById('first_name').value,
            last_name: document.getElementById('last_name').value,
            phone: document.getElementById('phone').value,
            email: document.getElementById('email').value,
            hire_date: document.getElementById('hire_date').value // 🌟 ส่งวันที่เริ่มงานไปให้หลังบ้าน
        };

        try {
            const response = await axios.put(`http://localhost:5000/api/technicians/${currentTechId}`, updateData);
            
            if (response.data.success) {
                alert('✅ ' + response.data.message);
                window.location.href = '/technicians'; // กลับหน้ารายชื่อช่าง
            }
        } catch (error) {
            console.error("อัปเดตพลาด:", error);
            alert('❌ อัปเดตข้อมูลไม่สำเร็จ กรุณาลองใหม่อีกครั้ง');
        }
    });

    // เริ่มทำงานทันที
    loadTechData();
</script>

</body>
</html>