<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <h2 class="fw-bold" style="color: var(--sidebar-bg);">
            <i class="bi bi-person-badge text-warning me-2"></i>แก้ไขข้อมูลช่างซ่อม <span id="headerTechId" class="text-primary"></span>
        </h2>
        <a href="/technicians" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-arrow-left"></i> ยกเลิก / กลับ
        </a>
    </div>

    <div id="loadingBox" class="text-center py-5">
        <div class="spinner-border text-warning" role="status" style="width: 3rem; height: 3rem;"></div>
        <h5 class="mt-3 text-muted">กำลังดึงข้อมูลช่างซ่อม...</h5>
    </div>

    <div class="card shadow-sm border-0 rounded-3 mx-auto" id="editFormBox" style="max-width: 800px; display: none;">
        <div class="card-body p-4 p-md-5">
            <form id="editTechnicianForm">
                
                <div class="row mb-3">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <label class="form-label fw-bold text-secondary">ชื่อจริง <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-lg bg-light" id="firstName" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-secondary">นามสกุล <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-lg bg-light" id="lastName" required>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <label class="form-label fw-bold text-secondary">เบอร์โทรศัพท์ <span class="text-danger">*</span></label>
                        <input type="tel" class="form-control form-control-lg bg-light" id="phone" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-secondary">อีเมล</label>
                        <input type="email" class="form-control form-control-lg bg-light" id="email">
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary"><i class="bi bi-star-fill text-warning me-1"></i> ความเชี่ยวชาญเฉพาะทาง (Specialty)</label>
                    <input type="text" class="form-control form-control-lg bg-light" id="specialty">
                </div>

                <hr class="mb-4">

                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    <button type="submit" class="btn btn-warning fw-bold text-dark btn-lg px-5 shadow-sm">
                        <i class="bi bi-save me-2"></i> บันทึกการแก้ไข
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // ดึงตัวแปร ID ช่างที่ส่งมาจาก Backend
    const currentTechnicianId = '<%= technicianId %>';

    // ==========================================
    // 1. ฟังก์ชันดึงข้อมูลเก่ามาใส่ฟอร์ม
    // ==========================================
    async function loadTechnicianData() {
        try {
            const response = await axios.get(`http://localhost:5000/api/technicians/${currentTechnicianId}`);
            const data = response.data.data;

            // นำข้อมูลไปหยอดลงช่อง Input
            const techIdFormatted = String(data.technician_id).padStart(3, '0');
            document.getElementById('headerTechId').innerText = `(TECH-${techIdFormatted})`;
            
            document.getElementById('firstName').value = data.first_name || '';
            document.getElementById('lastName').value = data.last_name || '';
            document.getElementById('phone').value = data.phone || '';
            document.getElementById('email').value = data.email || '';
            document.getElementById('specialty').value = data.specialty || '';

            // ปิดตัวโหลด เปิดกล่องฟอร์ม
            document.getElementById('loadingBox').style.display = 'none';
            document.getElementById('editFormBox').style.display = 'block';

        } catch (error) {
            console.error("ดึงข้อมูลพลาด:", error);
            document.getElementById('loadingBox').innerHTML = `<h5 class="text-danger mt-3">❌ ไม่พบข้อมูลช่างซ่อม หรือระบบมีปัญหา</h5>`;
        }
    }

    // ==========================================
    // 2. ฟังก์ชันส่งข้อมูลใหม่ไปอัปเดต
    // ==========================================
    document.getElementById('editTechnicianForm').addEventListener('submit', async function(e) {
        e.preventDefault(); 

        const data = {
            first_name: document.getElementById('firstName').value,
            last_name: document.getElementById('lastName').value,
            phone: document.getElementById('phone').value,
            email: document.getElementById('email').value,
            specialty: document.getElementById('specialty').value
        };

        try {
            // ใช้ axios.put (แก้ไขข้อมูล) ไปที่หลังบ้าน
            const response = await axios.put(`http://localhost:5000/api/technicians/${currentTechnicianId}`, data);

            if (response.data.success) {
                alert('✅ ' + response.data.message);
                window.location.href = '/technicians'; // เด้งกลับไปหน้ารายชื่อช่าง
            }
        } catch (error) {
            console.error("ส่งข้อมูลแก้ไขพลาด:", error);
            alert('❌ เกิดข้อผิดพลาด ไม่สามารถแก้ไขข้อมูลได้');
        }
    });

    // ให้ดึงข้อมูลมาแสดงทันทีที่เปิดหน้าเว็บ
    loadTechnicianData();
</script>

</body>
</html>