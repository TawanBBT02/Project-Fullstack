<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <h2 class="fw-bold" style="color: var(--sidebar-bg);">
            <i class="bi bi-search text-info me-2"></i>รายละเอียดงานซ่อม <span id="headerRepairId" class="text-primary"></span>
        </h2>
        <div>
            <a href="/repairs" class="btn btn-outline-secondary shadow-sm me-2">
                <i class="bi bi-arrow-left"></i> กลับ
            </a>
            <button class="btn btn-primary shadow-sm" onclick="window.print()">
                <i class="bi bi-printer"></i> พิมพ์ใบรับซ่อม
            </button>
        </div>
    </div>

    <div id="loadingBox" class="text-center py-5">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
        <h5 class="mt-3 text-muted">กำลังโหลดข้อมูล...</h5>
    </div>

    <div id="contentBox" style="display: none;">
        <div class="row g-4">
            
            <div class="col-12">
                <div class="card shadow-sm border-0 border-start border-info border-4">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-md-3 border-end">
                                <p class="text-muted mb-1 small fw-bold">วันที่รับเครื่อง</p>
                                <h5 class="fw-bold mb-0" id="dt-receiveDate">-</h5>
                            </div>
                            <div class="col-md-6 border-end px-4">
                                <p class="text-muted mb-1 small fw-bold">อาการเสีย / รายละเอียดที่แจ้ง</p>
                                <p class="mb-0 text-dark" id="dt-description">-</p>
                            </div>
                            <div class="col-md-3 text-center">
                                <p class="text-muted mb-2 small fw-bold">สถานะงานซ่อมปัจจุบัน</p>
                                <div id="dt-statusBox"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm border-0 h-100 mb-4">
                    <div class="card-header bg-white border-bottom fw-bold py-3">
                        <i class="bi bi-person-fill text-primary me-2"></i>ข้อมูลลูกค้า
                    </div>
                    <div class="card-body">
                        <h5 class="fw-bold text-dark mb-3" id="dt-custName">-</h5>
                        <p class="mb-2"><i class="bi bi-telephone text-muted me-2"></i> <span id="dt-custPhone">-</span></p>
                        <p class="mb-2"><i class="bi bi-envelope text-muted me-2"></i> <span id="dt-custEmail">-</span></p>
                        <p class="mb-0"><i class="bi bi-geo-alt text-muted me-2"></i> <span id="dt-custAddress">-</span></p>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-white border-bottom fw-bold py-3">
                        <i class="bi bi-pc-display text-primary me-2"></i>ข้อมูลอุปกรณ์ที่ซ่อม
                    </div>
                    <div class="card-body">
                        <h5 class="fw-bold text-dark mb-2"><span id="dt-devBrand">-</span> <span id="dt-devModel"></span></h5>
                        <p class="mb-0 text-muted"><i class="bi bi-tag me-2"></i> รายละเอียด: <span class="badge bg-light text-dark border" id="dt-devType">-</span></p>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-sm-6">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-header bg-white border-bottom fw-bold py-3">
                                <i class="bi bi-tools text-warning me-2"></i>ช่างผู้รับผิดชอบ
                            </div>
                            <div class="card-body text-center">
                                <h6 class="fw-bold mb-2" id="dt-techName">-</h6>
                                <p class="small text-muted mb-0"><i class="bi bi-telephone"></i> <span id="dt-techPhone">-</span></p>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-header bg-white border-bottom fw-bold py-3">
                                <i class="bi bi-cash-coin text-success me-2"></i>ข้อมูลการชำระเงิน
                            </div>
                            <div class="card-body text-center">
                                <h5 class="fw-bold text-success mb-2" id="dt-payAmount">รอการประเมิน</h5>
                                <div id="dt-payStatusBox"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<%- include('partials/footer') %>

<script>
    // 🌟 ดึง ID จาก URL แทนการใช้ EJS ชัวร์กว่าครับ (เช่น /repair-details/27 -> จะได้เลข 27)
    const urlParts = window.location.pathname.split('/');
    const currentRepairId = urlParts[urlParts.length - 1];

    async function loadRepairDetails() {
        try {
            // ยิง API ไปที่หลังบ้าน
            const response = await axios.get(`http://localhost:5000/api/repairs/${currentRepairId}`);
            const data = response.data.data;

            // --- จัดการหัวข้อ ---
            const repIdFormatted = String(data.repair_id).padStart(3, '0');
            document.getElementById('headerRepairId').innerText = `(REP-${repIdFormatted})`;

            // --- จัดการข้อมูลงานซ่อม ---
            document.getElementById('dt-receiveDate').innerText = data.receive_date || '-';
            document.getElementById('dt-description').innerText = data.problem_type || data.description || 'ไม่ระบุอาการเสีย';
            
            // ป้ายสถานะงาน
            let statusBadge = '';
            if(data.status === 'Pending') statusBadge = '<span class="badge bg-secondary fs-6 rounded-pill px-3 py-2">รอดำเนินการ</span>';
            else if(data.status === 'In Progress') statusBadge = '<span class="badge fs-6 rounded-pill px-3 py-2" style="background-color: #ff6b00;">กำลังซ่อม</span>';
            else if(data.status === 'Completed') statusBadge = '<span class="badge bg-success fs-6 rounded-pill px-3 py-2">ซ่อมเสร็จสิ้น</span>';
            else statusBadge = `<span class="badge bg-dark fs-6 rounded-pill px-3 py-2">${data.status || 'ไม่ระบุ'}</span>`;
            document.getElementById('dt-statusBox').innerHTML = statusBadge;

            // --- จัดการข้อมูลลูกค้า 🌟 (แก้ชื่อตัวแปรให้ตรงกับตารางของเรา) ---
            document.getElementById('dt-custName').innerText = `${data.first_name || 'ไม่ระบุ'} ${data.last_name || ''}`;
            document.getElementById('dt-custPhone').innerText = data.phone || 'ไม่มีเบอร์โทร';
            document.getElementById('dt-custEmail').innerText = data.email || 'ไม่มีอีเมล';
            document.getElementById('dt-custAddress').innerText = data.address || 'ไม่ระบุที่อยู่';

            // --- จัดการข้อมูลอุปกรณ์ 🌟 (แก้ชื่อตัวแปรให้ตรงกับตารางของเรา) ---
            document.getElementById('dt-devBrand').innerText = data.brand || 'ไม่ระบุยี่ห้อ';
            document.getElementById('dt-devModel').innerText = data.model || '';
            document.getElementById('dt-devType').innerText = data.device_type || 'ไม่มีรายละเอียด';

            // --- จัดการข้อมูลช่าง ---
            document.getElementById('dt-techName').innerText = `ช่าง${data.tech_first || 'ไม่ระบุ'} ${data.tech_last || ''}`;
            document.getElementById('dt-techPhone').innerText = data.tech_phone || '-';

            // --- จัดการข้อมูลการชำระเงิน ---
            if (data.amount != null) {
                const amountFormatted = Number(data.amount).toLocaleString('th-TH', { minimumFractionDigits: 2 });
                document.getElementById('dt-payAmount').innerText = `฿${amountFormatted}`;
                
                if(data.payment_status === 'Paid' || data.payment_status === 'ชำระแล้ว') {
                    document.getElementById('dt-payStatusBox').innerHTML = `<span class="badge bg-success">ชำระแล้ว</span>`;
                } else if(data.payment_status === 'Unpaid' || data.payment_status === 'ค้างชำระ') {
                    document.getElementById('dt-payStatusBox').innerHTML = `<span class="badge bg-danger">ค้างชำระ</span>`;
                } else {
                    document.getElementById('dt-payStatusBox').innerHTML = `<span class="badge bg-secondary">${data.payment_status || 'ไม่ระบุ'}</span>`;
                }
            } else {
                document.getElementById('dt-payStatusBox').innerHTML = `<span class="badge bg-light text-muted border">ยังไม่มีรายการบิล</span>`;
            }

            // ซ่อนที่โหลด เปิดข้อมูลโชว์
            document.getElementById('loadingBox').style.display = 'none';
            document.getElementById('contentBox').style.display = 'block';

        } catch (error) {
            console.error("ดึงข้อมูลพลาด:", error);
            document.getElementById('loadingBox').innerHTML = `
                <div class="text-danger py-4">
                    <i class="bi bi-x-circle fs-1 mb-3 d-block"></i>
                    <h5>ไม่สามารถดึงข้อมูลรายละเอียดได้</h5>
                    <p class="text-muted">โปรดตรวจสอบการเชื่อมต่อหรือข้อมูลอาจถูกลบไปแล้ว</p>
                    <a href="/repairs" class="btn btn-outline-secondary mt-2">กลับหน้ารายการ</a>
                </div>
            `;
        }
    }

    // ทำงานทันทีที่โหลดหน้าเสร็จ
    loadRepairDetails();
</script>

</body>
</html>