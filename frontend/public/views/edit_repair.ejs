<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <h2 class="fw-bold text-dark">
            <i class="bi bi-tools text-warning me-2"></i>อัปเดตสถานะงานซ่อม <span id="displayRepairId" class="text-primary"></span>
        </h2>
        <a href="/repairs" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-arrow-left"></i> กลับหน้ารายการ
        </a>
    </div>

    <div id="errorBox" class="text-center py-5" style="display: none;">
        <h4 class="text-danger fw-bold"><i class="bi bi-x-circle-fill me-2"></i>ไม่พบข้อมูลงานซ่อม หรือระบบมีปัญหา</h4>
        <p class="text-muted" id="errorMessage"></p>
        <a href="/repairs" class="btn btn-outline-secondary mt-3">กลับหน้ารายการ</a>
    </div>

    <div class="card shadow-sm border-0 rounded-3" style="max-width: 800px; margin: 0 auto;" id="formCard">
        <div class="card-body p-5">
            <form id="editRepairForm">
                
                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary">อุปกรณ์ที่ส่งซ่อม <span class="text-danger">*</span></label>
                    <select class="form-select form-select-lg" id="device_id" required>
                        <option value="">-- กำลังโหลดข้อมูล --</option>
                    </select>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-secondary">วันที่รับเครื่อง <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" id="receive_date" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-secondary">ช่างรับผิดชอบ <span class="text-danger">*</span></label>
                        <select class="form-select" id="technician_id" required>
                            <option value="">-- กำลังโหลดข้อมูล --</option>
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary">อาการเสีย / รายละเอียดที่ลูกค้าแจ้ง <span class="text-danger">*</span></label>
                    <textarea class="form-control" id="problem_type" rows="3" required></textarea>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary">อัปเดตสถานะงานซ่อม <span class="text-danger">*</span></label>
                    <select class="form-select form-select-lg text-primary fw-bold bg-light" id="status" required>
                        <option value="Pending">⏳ รอดำเนินการ (Pending)</option>
                        <option value="In Progress">🔧 กำลังซ่อม (In Progress)</option>
                        <option value="Completed">✅ ซ่อมเสร็จสิ้น (Completed)</option>
                    </select>
                </div>

                <hr class="mb-4">

                <div class="text-end">
                    <button type="submit" class="btn btn-warning fw-bold px-5 shadow-sm">
                        <i class="bi bi-save me-2"></i>บันทึกการอัปเดต
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('partials/footer') %>

<script>
    // 🌟 ดึง ID จาก URL ให้แม่นยำ
    const urlParts = window.location.pathname.split('/');
    const currentRepairId = urlParts[urlParts.length - 1];

    async function loadFormData() {
        try {
            // 1. โหลดข้อมูลที่เกี่ยวข้องทั้งหมด
            const [devicesRes, techsRes, repairRes] = await Promise.all([
                axios.get('http://localhost:5000/api/devices'),
                axios.get('http://localhost:5000/api/technicians'),
                axios.get(`http://localhost:5000/api/repairs/${currentRepairId}`)
            ]);

            // เอาข้อมูลมายัดใส่ Dropdown อุปกรณ์
            let devOptions = '<option value="">-- เลือกอุปกรณ์ --</option>';
            devicesRes.data.data.forEach(d => {
                devOptions += `<option value="${d.device_id}">DEV-${String(d.device_id).padStart(3, '0')} | ${d.brand} ${d.model}</option>`;
            });
            document.getElementById('device_id').innerHTML = devOptions;

            // เอาข้อมูลมายัดใส่ Dropdown ช่าง
            let techOptions = '<option value="">-- เลือกช่าง --</option>';
            techsRes.data.data.forEach(t => {
                techOptions += `<option value="${t.technician_id}">ช่าง${t.first_name} ${t.last_name || ''}</option>`;
            });
            document.getElementById('technician_id').innerHTML = techOptions;

            // 2. นำข้อมูลงานซ่อมเดิม มากรอกลงในฟอร์ม
            const r = repairRes.data.data;
            document.getElementById('displayRepairId').innerText = `(REP-${String(r.repair_id).padStart(3, '0')})`;
            
            document.getElementById('device_id').value = r.device_id;
            document.getElementById('technician_id').value = r.technician_id;
            document.getElementById('receive_date').value = r.receive_date;
            
            // 🌟 ซิงค์กันเรียบร้อย ข้อมูลลงกล่องแน่นอน
            document.getElementById('problem_type').value = r.problem_type || r.description || ''; 
            document.getElementById('status').value = r.status;

        } catch (error) {
            console.error("โหลดข้อมูลพลาด:", error);
            // ถ้าพังจริงๆ ถึงจะซ่อนฟอร์ม แล้วโชว์กล่อง Error
            document.getElementById('formCard').style.display = 'none';
            document.getElementById('errorBox').style.display = 'block';
            document.getElementById('errorMessage').innerText = "ข้อผิดพลาด: " + error.message;
        }
    }

    // 3. เมื่อกดอัปเดต
    document.getElementById('editRepairForm').addEventListener('submit', async function(e) {
        e.preventDefault();

        const updateData = {
            device_id: document.getElementById('device_id').value,
            technician_id: document.getElementById('technician_id').value,
            receive_date: document.getElementById('receive_date').value,
            description: document.getElementById('problem_type').value, // ส่งข้อมูลให้หลังบ้าน
            status: document.getElementById('status').value
        };

        try {
            const response = await axios.put(`http://localhost:5000/api/repairs/${currentRepairId}`, updateData);
            
            if (response.data.success) {
                alert('✅ ' + response.data.message);
                window.location.href = '/repairs';
            }
        } catch (error) {
            console.error("อัปเดตพลาด:", error);
            alert('❌ อัปเดตข้อมูลไม่สำเร็จ กรุณาลองใหม่อีกครั้ง');
        }
    });

    // เริ่มโหลดข้อมูลทันที
    loadFormData();
</script>

</body>
</html>