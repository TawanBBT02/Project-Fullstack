<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<style>
    @media print {
        .sidebar, .navbar, .btn, .filter-box { display: none !important; }
        .container-fluid { padding: 0 !important; width: 100% !important; }
        .card { border: none !important; box-shadow: none !important; }
        .print-break { page-break-before: auto; }
    }
</style>

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <h2 class="fw-bold" style="color: var(--sidebar-bg);">
            <i class="bi bi-wallet2 text-success me-2"></i>รายงานรายรับ และผลงานช่าง
        </h2>
        <div>
            <button class="btn btn-outline-success me-2" onclick="window.print()">
                <i class="bi bi-printer-fill"></i> พิมพ์สรุปยอด
            </button>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4 filter-box bg-light">
        <div class="card-body">
            <form id="filterForm" class="row g-3 align-items-end">
                <div class="col-md-9">
                    <label class="form-label fw-bold text-secondary"><i class="bi bi-person-fill-gear me-1"></i> เลือกดูช่าง (เว้นว่างเพื่อดูผลงานของช่างทุกคน)</label>
                    <select class="form-select form-select-lg" id="filterTechnicianId">
                        <option value="" selected>-- 👨‍🔧 แสดงรายได้ของช่างทุกคน --</option>
                        </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-success btn-lg fw-bold w-100 shadow-sm">
                        <i class="bi bi-funnel-fill me-2"></i> กรองข้อมูล
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- <h5 class="fw-bold text-secondary mb-3"><i class="bi bi-person-lines-fill me-2"></i>สรุปรายได้แยกตามช่าง (นับเฉพาะบิลที่ชำระแล้ว)</h5> -->
    <div class="row g-3 mb-4" id="techSummaryBox">
        </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card bg-success text-white shadow-sm border-0 h-100 py-2">
                <div class="card-body text-center">
                    <div class="text-uppercase mb-1 fw-bold"><i class="bi bi-cash-stack me-2"></i>รายรับรวมทั้งหมด</div>
                    <h2 class="fw-bold mb-0" id="totalRevenue">฿0.00</h2>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-success text-success shadow-sm border-2 h-100 py-2">
                <div class="card-body text-center">
                    <div class="text-uppercase mb-1 fw-bold"><i class="bi bi-receipt me-2"></i>จำนวนบิลที่รับชำระ</div>
                    <h2 class="fw-bold mb-0" id="totalBills">0 <span class="fs-5 text-muted fw-normal">รายการ</span></h2>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-dark text-white fw-bold py-3">
            <i class="bi bi-list-columns-reverse me-2"></i>รายละเอียดรายการชำระเงิน
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ช่างผู้รับผิดชอบ</th>
                            <th class="text-center">วันที่ชำระ</th>
                            <th class="text-center">รหัสบิล</th>
                            <th>ลูกค้า</th>
                            <th class="text-center">สถานะบิล</th>
                            <th class="text-end pe-4">ยอดเงิน (บาท)</th>
                        </tr>
                    </thead>
                    <tbody id="revenueTableBody">
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <div class="spinner-border spinner-border-sm text-success me-2" role="status"></div> กำลังคำนวณยอดบัญชี...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    // 1. โหลดรายชื่อช่างเข้า Dropdown
    async function loadTechnicianFilter() {
        try {
            const response = await axios.get('http://localhost:5000/api/technicians');
            const techs = response.data.data;
            let options = '<option value="" selected>-- 👨‍🔧 แสดงรายได้ของช่างทุกคน --</option>';
            techs.forEach(t => {
                options += `<option value="${t.technician_id}">ช่าง${t.first_name} ${t.last_name || ''}</option>`;
            });
            document.getElementById('filterTechnicianId').innerHTML = options;
        } catch (error) { console.error("โหลดช่างพลาด:", error); }
    }

    // 2. โหลดรายงานและคำนวณยอดแยกช่าง (ไม่ต้องมีวันที่แล้ว)
    async function loadRevenueReport(techId = '') {
        try {
            let url = 'http://localhost:5000/api/reports/revenue';
            if(techId) url += `?technicianId=${techId}`;

            const response = await axios.get(url);
            const records = response.data.data;
            
            let html = '';
            let sumTotal = 0;
            let countPaidBills = 0;
            
            let techRevenueObj = {}; 

            if (records.length === 0) {
                html = `<tr><td colspan="6" class="text-center py-5 text-danger fw-bold">ไม่พบข้อมูลการรับเงิน</td></tr>`;
            } else {
                records.forEach(p => {
                    const payId = String(p.payment_id).padStart(3, '0');
                    const amount = Number(p.amount || 0);
                    const techName = (p.tech_first || p.tech_last) ? `ช่าง${p.tech_first || ''}` : 'ไม่ระบุช่าง';
                    let isPaid = (p.status === 'Paid' || p.status === 'ชำระแล้ว');
                    
                    if(isPaid) {
                        sumTotal += amount;
                        countPaidBills++;

                        if(!techRevenueObj[techName]) techRevenueObj[techName] = { amount: 0, bills: 0 };
                        techRevenueObj[techName].amount += amount;
                        techRevenueObj[techName].bills += 1;
                    }

                    const statusBadge = isPaid ? `<span class="badge bg-success">ชำระแล้ว</span>` : `<span class="badge bg-danger">ค้างชำระ</span>`;

                    html += `
                        <tr class="${!isPaid ? 'table-warning' : ''}">
                            <td class="text-primary fw-bold">${techName}</td>
                            <td class="text-center">${p.payment_date || '-'}</td>
                            <td class="text-center fw-bold text-secondary">
                                <a href="/repair-details/${p.repair_id}" class="text-decoration-none text-dark">PAY-${payId}</a>
                            </td>
                            <td>${p.first_name || '-'} ${p.last_name || ''}</td>
                            <td class="text-center">${statusBadge}</td>
                            <td class="text-end pe-4 fw-bold ${isPaid ? 'text-success' : 'text-danger'}">${amount.toLocaleString('th-TH', {minimumFractionDigits: 2})}</td>
                        </tr>
                    `;
                });
            }

            document.getElementById('revenueTableBody').innerHTML = html;
            document.getElementById('totalRevenue').innerText = `฿${sumTotal.toLocaleString('th-TH', {minimumFractionDigits: 2})}`;
            document.getElementById('totalBills').innerHTML = `${countPaidBills} <span class="fs-5 text-muted fw-normal">รายการ</span>`;
            /*
            // สร้างการ์ดแสดงยอดแยกตามช่าง
            let techCardsHtml = '';
            const techNames = Object.keys(techRevenueObj);
            
            if(techNames.length > 0) {
                techNames.forEach(name => {
                    const data = techRevenueObj[name];
                    techCardsHtml += `
                        <div class="col-md-3 col-sm-6">
                            <div class="card border-primary shadow-sm h-100">
                                <div class="card-body">
                                    <h6 class="card-title text-primary fw-bold mb-2">${name}</h6>
                                    <h4 class="fw-bold mb-1">฿${data.amount.toLocaleString('th-TH', {minimumFractionDigits: 2})}</h4>
                                    <div class="small text-muted">${data.bills} รายการบิล</div>
                                </div>
                            </div>
                        </div>
                    `;
                });
            } else {
                techCardsHtml = `<div class="col-12 text-muted fst-italic">ยังไม่มียอดชำระเงินที่เสร็จสมบูรณ์ในระบบ</div>`;
            }
            document.getElementById('techSummaryBox').innerHTML = techCardsHtml; 
            */

        } catch (error) {
            console.error("ดึงข้อมูลรายรับพลาด:", error);
            document.getElementById('revenueTableBody').innerHTML = `<tr><td colspan="6" class="text-center py-4 text-danger">ระบบมีปัญหา ไม่สามารถดึงข้อมูลได้</td></tr>`;
        }
    }

    // เมื่อกดปุ่มกรองข้อมูล
    document.getElementById('filterForm').addEventListener('submit', function(e) {
        e.preventDefault();
        const techId = document.getElementById('filterTechnicianId').value;
        
        document.getElementById('revenueTableBody').innerHTML = `<tr><td colspan="6" class="text-center py-4 text-muted"><div class="spinner-border spinner-border-sm text-success me-2"></div> กำลังคำนวณยอด...</td></tr>`;
        loadRevenueReport(techId);
    });

    // เริ่มต้นระบบ (โหลดช่างเสร็จปุ๊บ โหลดรายงานของทุกคนเลย)
    loadTechnicianFilter().then(() => {
        loadRevenueReport(''); // ค่าว่างคือดึงของช่างทุกคน
    });
</script>

</body>
</html>